# Copie este arquivo para .env.local e preencha. .env.local NÃO vai para o git.

# ---------------------------------------------------------------------------
# Banco de dados (obrigatório)
# ---------------------------------------------------------------------------
# Postgres. Em produção use a string do POOLER do provedor (Neon/Supabase),
# não a conexão direta — em serverless o número de conexões estoura rápido.
#
# Neon:     postgresql://user:senha@ep-xxx-pooler.região.aws.neon.tech/neondb?sslmode=require
# Supabase: postgresql://postgres.xxx:senha@aws-0-região.pooler.supabase.com:6543/postgres
#
# Desenvolvimento local com Docker:
#   docker run -d --name simulador-pg -e POSTGRES_PASSWORD=devpass \
#     -e POSTGRES_USER=simulador -e POSTGRES_DB=simulador \
#     -p 55433:5432 postgres:16-alpine
DATABASE_URL="postgresql://simulador:devpass@localhost:55433/simulador?sslmode=disable"

# ---------------------------------------------------------------------------
# Admin inicial — usado só por `npm run db:seed-admin`
# ---------------------------------------------------------------------------
ADMIN_NOME="Joao Bueno"
ADMIN_EMAIL="admin@emconta.com.br"
ADMIN_SENHA="troque-esta-senha"

# ---------------------------------------------------------------------------
# PDF (opcional)
# ---------------------------------------------------------------------------
# Caminho do Chrome/Chromium. Só é necessário quando o Chromium que o Puppeteer
# baixa não pode ser usado — antivírus corporativo, por exemplo.
#
# Windows:
# PUPPETEER_EXECUTABLE_PATH="C:\Program Files\Google\Chrome\Application\chrome.exe"
#
# Linux / Docker:
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome
